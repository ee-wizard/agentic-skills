# Garia AI 绘图 API 配置
# 复制此文件为项目根目录的 .env 并填入实际值
#
# 使用方式:
#   1. 复制: copy .github\skills\garia-image-skill\scripts\.env.example .env
#   2. 编辑 .env 填入实际 API 密钥和地址
#   3. 运行: python .github/skills/garia-image-skill/scripts/generate_garia.py --input C2-光现象/images.json --output C2-光现象/c2-images

# Garia API 密钥（必填）
# 从 Garia 平台获取: https://www.garia.com
GARIA_API_KEY="your-garia-api-key-here"

# Garia API 地址（选填，不填则使用默认地址 https://api.garia.com）
GARIA_API_HOST="https://api.garia.com"

# 默认 AI 模型（选填）
# garia-v2  - 基础模型，速度快
# garia-pro - 专业模型，质量高（推荐）
# garia-vip - 高级模型，质量最佳
GARIA_MODEL="garia-pro"

# 默认图片质量（选填）
# auto / low / medium / high
GARIA_QUALITY="high"
